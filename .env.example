# Codebase Brain environment example.
# Keep this intentionally small.

# Optional for frontend-only local development against hosted Base44 backend:
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=

# Optional for backend public GitHub import / public PR fetch to reduce API rate-limit issues.
# Do not expose this in frontend code.
GITHUB_TOKEN=
CODEBASE_BRAIN_GITHUB_TOKEN=

# Future GitHub App integration secrets.
# Keep all feature flags false until the GitHub App implementation is intentionally enabled.
GITHUB_APP_ENABLED=false
GITHUB_WEBHOOK_PROCESSING_ENABLED=false
GITHUB_WEBHOOK_DELIVERY_LOGGING_ENABLED=false
GITHUB_INSTALLATION_LOGGING_ENABLED=false
GITHUB_PRIVATE_IMPORT_ENABLED=false
GITHUB_AUTO_ANALYZE_PRS=false
GITHUB_PR_POSTING_ENABLED=false
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Future phase: direct OpenAI backend integration, if we move outside Base44 Core.InvokeLLM.
OPENAI_API_KEY=
