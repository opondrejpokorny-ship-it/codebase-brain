# Codebase Brain environment example.
# Keep this intentionally small.

# Optional for frontend-only local development against hosted Base44 backend:
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=

# Optional for backend public GitHub import to reduce public API rate-limit issues.
# Do not expose this in frontend code.
GITHUB_TOKEN=
CODEBASE_BRAIN_GITHUB_TOKEN=

# Future phase: direct OpenAI backend integration, if we move outside Base44 Core.InvokeLLM.
OPENAI_API_KEY=
